{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "ignoreDeprecations": "6.0",
    "baseUrl": ".",
    "paths": {
      "@/*": ["renderer/src/*"],
      "@core-types/*": ["../../packages/core-types/src/*"]
    },
    "types": ["node", "electron-vite/node"]
  },
  "include": ["electron", "renderer/src", "electron.vite.config.ts"]
}
