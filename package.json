{
  "name": "envoy-ide-monorepo",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/vscode-oss",
    "apps/desktop",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run run -w apps/vscode-oss",
    "build": "npm run build -w apps/vscode-oss",
    "dev:legacy": "npm run dev -w apps/desktop",
    "build:legacy": "npm run build -w apps/desktop"
  }
}
