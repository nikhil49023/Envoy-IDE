{
  "name": "@cytos/core-types",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript domain types for Cytos IDE",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsc -p .",
    "typecheck": "tsc -p . --noEmit"
  },
  "devDependencies": {
    "typescript": "^5.5.4"
  }
}
